{
  "profile": "pi-extended",
  "station": {
    "id": "polar-pi-extended-01",
    "latitude": 40.7128,
    "longitude": -74.0060
  },
  "server": {
    "listen_addr": ":8080",
    "mcp_listen_addr": ":8081"
  },
  "storage": {
    "sqlite_path": "/var/lib/polar/polar.db"
  },
  "auth": {
    "service_token": "replace-me"
  },
  "features": {
    "enable_forecast": true,
    "enable_mcp": true
  },
  "polling": {
    "sensor_interval": 5000000000,
    "forecast_interval": 900000000000
  },
  "provider": {
    "open_meteo_url": "https://api.open-meteo.com/v1/forecast"
  }
}
